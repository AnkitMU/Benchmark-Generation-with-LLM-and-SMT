context Device
inv: (self.name.size() >= 20) and (not(self.name.size() >= 20))

-- #2 Association Exists (UNSAT) in OTAUpdate
-- Difficulty: easy
-- Mutation Strategy: self_contradiction
context OTAUpdate
inv: (self.targetDevice <> null) and (not(self.targetDevice <> null))

-- #3 Collect (Map) Operation (UNSAT) in User
-- Difficulty: hard
-- Mutation Strategy: self_contradiction
context User
inv: (self.alerts->collect(x | x.alertId)->notEmpty()) and (not(self.alerts->collect(x | x.alertId)->notEmpty()))

-- #4 Uniqueness Constraint (UNSAT) in Gateway
-- Difficulty: medium
-- Mutation Strategy: self_contradiction
context Gateway
inv: (self.connectedEdges->isUnique(x | x.memoryMB)) and (not(self.connectedEdges->isUnique(x | x.memoryMB)))

-- #5 Collection Unique Attribute Values (UNSAT) in Role
-- Difficulty: easy
-- Mutation Strategy: self_contradiction
