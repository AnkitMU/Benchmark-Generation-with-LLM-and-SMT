-- #1 Navigation Chain in Category
-- Difficulty: easy
context Category
inv: self.store.name <> ''

-- #2 Navigation Chain in Category
-- Difficulty: easy
context Category
inv: self.store.currency <> ''

-- #3 Navigation Chain in Order
-- Difficulty: medium
context Order
inv: self.customer.cart.createdAt <> ''

-- #4 Collection Navigation in Cart
-- Difficulty: difficult
context Cart
inv: self.items->exists(x | x.quantity <= 100)

-- #5 Collection Navigation in Coupon
-- Difficulty: difficult
context Coupon
inv: self.orders->forAll(x | x.orderNo <> '')

-- #6 Association Exists in Customer
-- Difficulty: medium
context Customer
inv: (self.cart <> null) and (self.cart.oclIsTypeOf(Cart))

-- #7 Association Exists in Address
-- Difficulty: easy
