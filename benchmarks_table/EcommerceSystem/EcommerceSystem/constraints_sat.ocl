-- #24 Existential Quantification (exists) in Customer
-- Difficulty: difficult
context Customer
inv: self.orders->exists(x | x.placedAt <> '')

-- #25 Any Operation in Store
-- Difficulty: difficult
context Store
inv: self.coupons->any(x | x.code <> '') <> null

-- #26 Numeric Is Even in Review
-- Difficulty: easy
context Review
inv: self.rating mod 2 = 0

-- #27 Numeric Attribute Bounded in DiscountRule
-- Difficulty: medium
