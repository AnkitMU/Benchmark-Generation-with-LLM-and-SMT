-- #44 Collection Not Empty Check in IoTPlatform
-- Difficulty: easy
context IoTPlatform
inv: self.accessPolicies->size() > 0

-- #45 Collection Has Specific Size in Gateway
-- Difficulty: easy
context Gateway
inv: self.connectedEdges->size() = 1

-- #46 Attribute Not Null (Simple) in ConfigurationProfile
-- Difficulty: medium
context ConfigurationProfile
inv: (self.profileId <> null) and (self.device.oclIsTypeOf(Device))

-- #47 Collection Minimum Size in OTAUpdate
-- Difficulty: medium
context OTAUpdate
inv: self.tickets->size() >= 1

-- #48 Attribute Not Null (Simple) in TelemetryRecord
-- Difficulty: easy
context TelemetryRecord
inv: self.timestamp <> null

-- #49 Attribute Not Null (Simple) in MaintenanceTicket
-- Difficulty: easy
context MaintenanceTicket
inv: self.status <> null

-- #50 Attribute Not Null (Simple) in EventLog
-- Difficulty: easy
context EventLog
inv: self.time <> null

-- #51 Attribute Not Null (Simple) in MaintenanceTicket
-- Difficulty: easy
context MaintenanceTicket
inv: self.openedAt <> null

-- #52 Attribute Not Null (Simple) in EventLog
-- Difficulty: medium
context EventLog
inv: (self.message <> null) and (self.message.size() <= 30)

-- #53 Attribute Not Null (Simple) in ConfigurationProfile
-- Difficulty: easy
context ConfigurationProfile
inv: self.updatedAt <> null

-- #54 Collection Maximum Size in AccessPolicy
-- Difficulty: medium
context AccessPolicy
inv: self.roles->size() <= 1

-- #55 Collection Maximum Size in ConnectivityModule
-- Difficulty: medium
context ConnectivityModule
inv: self.links->size() <= 3

-- #56 Collection Not Empty (Simple) in AlertRule
-- Difficulty: easy
context AlertRule
inv: self.alerts->notEmpty()

-- #57 Collection Has Specific Size in ConnectivityModule
-- Difficulty: easy
context ConnectivityModule
inv: self.links->size() = 3

-- #58 Collection Has Specific Size in AlertRule
-- Difficulty: easy
context AlertRule
inv: self.alerts->size() = 2

-- #59 Collection Must Be Empty in DataStream
-- Difficulty: easy
context DataStream
inv: self.alertRules->isEmpty()

-- #60 Collection As Sequence Conversion in AlertRule
-- Difficulty: medium
context AlertRule
inv: self.alerts->asSequence()->notEmpty()

-- #61 Collection Minimum Size in Cluster
-- Difficulty: medium
context Cluster
inv: self.gateways->size() >= 1

-- #62 Collection Nested Collection Flatten in Cluster
-- Difficulty: difficult
context Cluster
inv: self.gateways->collect(x | x.connectedEdges)->size() >= 3

-- #63 Collection Nested Collection Flatten in Device
-- Difficulty: difficult
context Device
inv: self.dataStreams->collect(x | x.alertRules)->size() >= 3

-- #64 Collection Sum in SensorNode
-- Difficulty: difficult
