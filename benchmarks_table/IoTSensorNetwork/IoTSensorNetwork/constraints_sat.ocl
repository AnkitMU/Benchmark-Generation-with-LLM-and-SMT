-- Benchmark: IoTSensorNetwork / balanced
-- Type: SAT Constraints Only
-- Generated: 2026-06-18T17:32:59.825018
-- Count: 64

-- #1 Navigation Chain in EventLog
-- Difficulty: repair
context EventLog
inv: self.device.firmware.version <> ''

-- #2 Navigation Chain in EdgeNode
-- Difficulty: medium
context EdgeNode
inv: self.cluster.network.networkId <> ''

-- #3 Navigation Chain in Metric
-- Difficulty: easy
context Metric
inv: self.sensor.sampleRateHz > 10

-- #4 Navigation Chain in Role
-- Difficulty: easy
context Role
inv: self.platform.version <> ''

-- #5 Navigation Chain in Metric
-- Difficulty: easy
context Metric
inv: self.sensor.sampleRateHz >= 10

-- #6 Navigation Chain in TelemetryRecord
-- Difficulty: repair
context TelemetryRecord
inv: self.stream.device.name <> ''

-- #7 Navigation Chain in Role
-- Difficulty: easy
context Role
inv: self.platform.name <> ''

-- #8 Numeric Is Odd in SensorNode
-- Difficulty: easy
context SensorNode
inv: self.sampleRateHz mod 2 = 1

-- #9 Association Exists in CommunicationLink
-- Difficulty: easy
context CommunicationLink
inv: self.network <> null

-- #10 Association Exists in AlertRule
-- Difficulty: easy
context AlertRule
inv: self.stream <> null

-- #11 Association Exists in Alert
-- Difficulty: medium
context Alert
inv: (self.rule <> null) and (self.acknowledged = false)

-- #12 Association Exists in CommunicationLink
-- Difficulty: medium
context CommunicationLink
inv: (self.module <> null) and (self.linkId.size() <= 92)

-- #13 Association Exists in ConfigurationProfile
-- Difficulty: medium
context ConfigurationProfile
inv: (self.device <> null) and (self.profileId.size() = 44)

-- #14 Association Exists in Alert
-- Difficulty: medium
context Alert
inv: (self.assignedTo <> null) and (self.alertId.size() <= 42)

-- #15 Association Exists in APIKey
-- Difficulty: medium
context APIKey
inv: (self.user <> null) and (self.value.size() >= 18)

-- #16 Association Exists in ConnectivityModule
-- Difficulty: easy
context ConnectivityModule
inv: self.device <> null

-- #17 Association Exists in Device
-- Difficulty: easy
context Device
inv: self.firmware <> null

-- #18 Navigation Chain in Alert
-- Difficulty: medium
context Alert
inv: self.rule.stream.topic <> ''

-- #19 Navigation Chain in APIKey
-- Difficulty: medium
context APIKey
inv: self.user.platform.name <> ''

-- #20 Collection Navigation in AlertRule
-- Difficulty: difficult
context AlertRule
inv: self.alerts->exists(x | x.acknowledged <> true)

-- #21 Collection Navigation in Firmware
-- Difficulty: difficult
context Firmware
inv: self.devices->forAll(x | x.deviceId <> '')

-- #22 Collection Navigation in IoTPlatform
-- Difficulty: difficult
context IoTPlatform
inv: self.accessPolicies->exists(x | x.policyId <> '')

-- #23 Select (Filter) Operation in ConnectivityModule
-- Difficulty: difficult
context ConnectivityModule
inv: self.links->select(x | x.bandwidthKbps > 10)->size() >= 1

-- #24 Any Operation in Network
-- Difficulty: difficult
context Network
inv: self.links->any(x | x.bandwidthKbps >= 10) <> null

-- #25 Existential Quantification (exists) in SensorNode
-- Difficulty: difficult
context SensorNode
inv: self.metrics->exists(x | x.lastValue <= 50)

-- #26 Existential Quantification (exists) in Gateway
-- Difficulty: difficult
context Gateway
inv: self.connectedEdges->exists(x | x.memoryMB < 50)

-- #27 One Operation in Gateway
-- Difficulty: medium
context Gateway
inv: self.connectedEdges->one(x | x.memoryMB > 2)

-- #28 Numeric Is Odd in EdgeNode
-- Difficulty: easy
context EdgeNode
inv: self.cpuCores mod 2 = 1

-- #29 Numeric Absolute Value Bounded in ActuatorNode
-- Difficulty: medium
context ActuatorNode
inv: self.maxLoad.abs() <= 5

-- #30 Numeric Multiple Of in Battery
-- Difficulty: easy
context Battery
inv: self.healthPct mod 9 = 0

-- #31 Numeric Attribute Positive in Location
-- Difficulty: easy
context Location
inv: self.longitude > 0

-- #32 Numeric Attribute Non-Negative in EdgeNode
-- Difficulty: easy
context EdgeNode
inv: self.cpuCores >= 0

-- #33 Numeric Greater Than Value in PowerSource
-- Difficulty: easy
context PowerSource
inv: self.capacity > 64

-- #34 Numeric Attribute Bounded in SolarPanel
-- Difficulty: medium
context SolarPanel
inv: self.wattPeak >= 58 and self.wattPeak <= 96

-- #35 Numeric Absolute Value Bounded in Battery
-- Difficulty: medium
context Battery
inv: self.healthPct.abs() <= 8

-- #36 Numeric Less Than Value in ActuatorNode
-- Difficulty: easy
context ActuatorNode
inv: self.maxLoad < 75

-- #37 Numeric Attribute Bounded in ActuatorNode
-- Difficulty: medium
context ActuatorNode
inv: self.maxLoad >= 64 and self.maxLoad <= 78

-- #38 Numeric Absolute Value Bounded in Location
-- Difficulty: medium
context Location
inv: self.longitude.abs() <= 5

-- #39 Numeric Absolute Value Bounded in PowerSource
-- Difficulty: medium
context PowerSource
inv: self.capacity.abs() <= 2

-- #40 Numeric Attribute Bounded in PowerSource
-- Difficulty: easy
context PowerSource
inv: (self.capacity <= 76)

-- #41 Collection Size in Range in OTAUpdate
-- Difficulty: medium
context OTAUpdate
inv: (self.tickets->size() <= 1)

-- #42 Collection Minimum Size in IoTPlatform
-- Difficulty: medium
context IoTPlatform
inv: self.networks->size() >= 3

-- #43 Collection Size Constraint in Firmware
-- Difficulty: medium
context Firmware
