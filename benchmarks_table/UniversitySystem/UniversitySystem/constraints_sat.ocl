-- #36 Numeric Absolute Value Bounded in Exam
-- Difficulty: medium
context Exam
inv: self.maxMarks.abs() <= 1

-- #37 Numeric Absolute Value Bounded in Exam
-- Difficulty: medium
context Exam
inv: self.maxMarks.abs() <= 0

-- #38 Numeric Attribute Bounded in CourseOffering
-- Difficulty: medium
context CourseOffering
inv: self.capacity >= 4 and self.capacity <= 60

-- #39 Numeric Comparison in Scholarship
-- Difficulty: medium
context Scholarship
