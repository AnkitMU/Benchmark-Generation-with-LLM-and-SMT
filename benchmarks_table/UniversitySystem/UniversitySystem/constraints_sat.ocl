-- #25 Numeric Is Even in Semester
-- Difficulty: easy
context Semester
inv: self.year mod 2 = 0

-- #26 Numeric Absolute Value Bounded in Room
-- Difficulty: difficult
context Room
inv: (self.capacity > 5) and (self.offerings->forAll(v | v.capacity < 10))

-- #27 Any Operation in Instructor
-- Difficulty: difficult
context Instructor
inv: self.offerings->any(x | x.capacity <= 50) <> null

-- #28 One Operation in University
-- Difficulty: medium
context University
inv: self.buildings->one(x | x.name <> '')

-- #29 Numeric Difference Constraint in Scholarship
-- Difficulty: easy
context Scholarship
inv: self.endYear - self.startYear >= 9

-- #30 Numeric Sum Constraint in Scholarship
-- Difficulty: easy
context Scholarship
inv: self.endYear + self.startYear > 3

-- #31 Collection Size in Range in University
-- Difficulty: easy
context University
inv: (self.faculties->size() <= 1)

-- #32 Numeric Comparison in Scholarship
-- Difficulty: easy
context Scholarship
inv: self.endYear <> self.startYear

-- #33 Numeric Is Even in Course
-- Difficulty: easy
