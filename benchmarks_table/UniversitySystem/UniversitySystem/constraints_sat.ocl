-- #40 Minimum Of Two Attributes in Scholarship
-- Difficulty: medium
context Scholarship
inv: if self.endYear < self.startYear then self.endYear else self.startYear endif >= 40

-- #41 Numeric Attribute Non-Negative in Course
-- Difficulty: medium
context Course
inv: (self.credits >= 0) and (self.offerings->isEmpty())

-- #42 Numeric Attribute Bounded in Course
-- Difficulty: medium
