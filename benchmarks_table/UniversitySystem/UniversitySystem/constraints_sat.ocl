-- #16 Navigation Chain in Exam
-- Difficulty: medium
context Exam
inv: (self.offering.course.credits > 5) and (self.type.toLowerCase() = 'test')

-- #17 Navigation Chain in GradeRecord
-- Difficulty: medium
context GradeRecord
inv: self.enrollment.student.yearOfStudy >= 1

-- #18 Navigation Chain in GradeRecord
-- Difficulty: medium
context GradeRecord
inv: self.enrollment.student.yearOfStudy >= 5

-- #19 Collection Navigation in Room
-- Difficulty: difficult
context Room
inv: self.offerings->exists(x | x.capacity <= 50)

-- #20 Collection Navigation in Program
-- Difficulty: difficult
context Program
inv: self.students->forAll(x | x.yearOfStudy <= 10)

-- #21 Collection Navigation in Department
-- Difficulty: difficult
context Department
inv: self.staff->forAll(x | x.role <> '')

-- #22 Collection Navigation in Student
-- Difficulty: difficult
context Student
inv: self.enrollments->exists(x | x.enrolledAt <> '')

-- #23 Numeric Is Odd in Program
-- Difficulty: easy
context Program
inv: self.durationYears mod 2 = 1

-- #24 Numeric Attribute Positive in Student
-- Difficulty: easy
context Student
