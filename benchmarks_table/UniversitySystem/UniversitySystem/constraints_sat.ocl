-- Difficulty: medium
context Course
inv: self.offerings->size() <= 2

-- #56 Bi-directional Implication in Semester
-- Difficulty: medium
context Semester
inv: (self.startDate <> null) = (self.endDate <> null)

-- #57 Collection Size Constraint in Course
-- Difficulty: medium
context Course
inv: (self.offerings->size() < 1) and (self.department.oclIsTypeOf(Department))

-- #58 Collection Minimum Size in Building
-- Difficulty: medium
context Building
inv: self.rooms->size() >= 3

-- #59 Bi-directional Implication in Semester
-- Difficulty: medium
context Semester
inv: (self.endDate <> null) = (self.startDate <> null)

-- #60 Collection Nested Collection Flatten in Building
-- Difficulty: difficult
context Building
inv: self.rooms->collect(x | x.offerings)->size() >= 1

-- #61 Reverse Implication in Semester
-- Difficulty: medium
context Semester
inv: self.endDate <> null implies self.startDate <> null

-- #62 Collection Has Specific Size in Department
-- Difficulty: easy
