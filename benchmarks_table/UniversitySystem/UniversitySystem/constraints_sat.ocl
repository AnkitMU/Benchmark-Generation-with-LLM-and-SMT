-- Difficulty: easy
context Course
inv: self.offerings->size() <> 1

-- #49 Collection Has Specific Size in Exam
-- Difficulty: easy
context Exam
inv: self.attempts->size() = 3

-- #50 Collection Not Empty (Simple) in CourseOffering
-- Difficulty: easy
context CourseOffering
inv: self.enrollments->notEmpty()

-- #51 Collection Minimum Size in Department
-- Difficulty: medium
context Department
inv: self.programs->size() >= 2

-- #52 Collection Maximum Size in Department
-- Difficulty: medium
context Department
inv: self.staff->size() <= 3

-- #53 Collection Minimum Size in Building
-- Difficulty: medium
context Building
